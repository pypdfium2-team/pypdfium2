        "musllinux_armv7l":  {"runner_os": "ubuntu-26.04-arm"},
        "manylinux_i686":    {"runner_os": "ubuntu-26.04"},
        "musllinux_i686":    {"runner_os": "ubuntu-26.04"},
        "manylinux_ppc64le": {"runner_os": "ubuntu-26.04", "use_sysroot": true},
        "musllinux_ppc64le": {"runner_os": "ubuntu-26.04"},
