        "linux_armv7l": {
            "runner_os": "ubuntu-26.04", "target_cpu": "arm",
            "test_os": "ubuntu-26.04-arm"
        },
        "linux_ppc64le": {"runner_os": "ubuntu-26.04", "target_cpu": "ppc64"},
        "linux_mips64le": {"runner_os": "ubuntu-24.04", "target_cpu": "mips64el"},
        "linux_mipsle": {
            "runner_os": "ubuntu-24.04", "target_cpu": "mipsel",
            "docker_test": false
        },
        "android_arm64_v8a": {
            "runner_os": "ubuntu-26.04",
            "target_os": "android", "target_cpu": "arm64"
        },
        "android_armeabi_v7a": {
            "runner_os": "ubuntu-26.04",
            "target_os": "android", "target_cpu": "arm"
