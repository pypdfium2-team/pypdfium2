{
    "pbin": {
        "macosx_arm64": {
            "target": "darwin_arm64", "runner_os": "macos-latest"},
        "macosx_x86_64": {
            "target": "darwin_x64", "runner_os": "macos-15-intel"},
        "macosx_universal2": {
            "target": "darwin_univ2", "runner_os": "macos-latest"},
        "win_amd64": {
            "target": "windows_x64", "runner_os": "windows-latest"},
        "win_arm64": {
            "target": "windows_arm64", "runner_os": "windows-11-vs2026-arm"},
        "win32": {
            "target": "windows_x86", "runner_os": "windows-latest"},
        "manylinux_x86_64": {
            "target": "linux_x64", "runner_os": "ubuntu-26.04"},
        "manylinux_i686": {
            "target": "linux_x86", "runner_os": "ubuntu-26.04"},
        "manylinux_aarch64": {
            "target": "linux_arm64", "runner_os": "ubuntu-26.04-arm"},
        "manylinux_armv7l": {
            "target": "linux_arm32", "runner_os": "ubuntu-26.04-arm"},
        "manylinux_ppc64le": {
            "target": "linux_ppc64le", "runner_os": "ubuntu-26.04"},
        "manylinux_mips64le": {
            "target": "linux_mips64le", "runner_os": "ubuntu-26.04"},
        "manylinux_mipsle": {
            "target": "linux_mipsle", "runner_os": "ubuntu-26.04"},
        "musllinux_x86_64": {
            "target": "linux_musl_x64", "runner_os": "ubuntu-26.04"},
        "musllinux_i686": {
            "target": "linux_musl_x86", "runner_os": "ubuntu-26.04"},
        "musllinux_aarch64": {
            "target": "linux_musl_arm64", "runner_os": "ubuntu-26.04"},
        "android_arm64_v8a": {
            "target": "android_arm64", "runner_os": "ubuntu-26.04"},
        "android_armeabi_v7a": {
            "target": "android_arm32", "runner_os": "ubuntu-26.04"},
        "android_x86_64": {
            "target": "android_x64", "runner_os": "ubuntu-26.04"},
        "android_x86": {
            "target": "android_x86", "runner_os": "ubuntu-26.04"},
        "ios_arm64_iphoneos": {
            "target": "ios_arm64_dev", "runner_os": "macos-latest"},
        "ios_arm64_iphonesimulator": {
            "target": "ios_arm64_simu", "runner_os": "macos-latest"},
        "ios_x86_64_iphonesimulator": {
            "target": "ios_x64_simu", "runner_os": "macos-15-intel"}
    },
    "cibw": {
        "macosx_arm64": {
            "runner_os": "macos-latest"},
        "macosx_x86_64": {
            "runner_os": "macos-15-intel"},
        "win_amd64": {
            "runner_os": "windows-latest", "cibw_arch": "AMD64"},
        "win_arm64": {
            "runner_os": "windows-latest", "test_os": "windows-11-vs2026-arm", "cibw_arch": "ARM64"},
        "win32": {
            "runner_os": "windows-latest", "cibw_arch": "x86"},
        "manylinux_x86_64": {
            "runner_os": "ubuntu-26.04"},
        "musllinux_x86_64": {
            "runner_os": "ubuntu-26.04"},
        "manylinux_aarch64": {
            "runner_os": "ubuntu-26.04-arm"},
        "musllinux_aarch64": {
            "runner_os": "ubuntu-26.04-arm"},
        "manylinux_armv7l": {
            "runner_os": "ubuntu-26.04-arm"},
        "musllinux_armv7l": {
            "runner_os": "ubuntu-26.04-arm"},
        "manylinux_i686": {
            "runner_os": "ubuntu-26.04"},
        "musllinux_i686": {
            "runner_os": "ubuntu-26.04"},
        "manylinux_ppc64le": {
            "runner_os": "ubuntu-26.04", "use_sysroot": true},
        "musllinux_ppc64le": {
            "runner_os": "ubuntu-26.04"},
        "manylinux_s390x": {
            "runner_os": "ubuntu-26.04"},
        "musllinux_s390x": {
            "runner_os": "ubuntu-26.04"},
        "manylinux_riscv64": {
            "runner_os": "ubuntu-26.04", "use_sysroot": true},
        "musllinux_riscv64": {
            "runner_os": "ubuntu-26.04"},
        "manylinux_loongarch64": {
            "runner_os": "ubuntu-26.04"},
        "musllinux_loongarch64": {
            "runner_os": "ubuntu-26.04"}
    },
    "sbuild": {
        "macosx_arm64": {
            "runner_os": "macos-latest"},
        "macosx_x86_64": {
            "runner_os": "macos-latest", "test_os": "macos-15-intel", "target_cpu": "x64"},
        "macosx_x86_64:native": {
            "runner_os": "macos-15-intel"},
        "win_amd64": {
            "runner_os": "windows-latest"},
        "win_arm64": {
            "runner_os": "windows-latest", "test_os": "windows-11-vs2026-arm", "target_cpu": "arm64"},
        "win32": {
            "runner_os": "windows-latest"},
        "win_arm64:native": {
            "runner_os": "windows-11-vs2026-arm"},
        "manylinux_x86_64": {
            "runner_os": "ubuntu-26.04"},
        "manylinux_i686": {
            "runner_os": "ubuntu-26.04", "target_cpu": "x86"},
        "manylinux_aarch64": {
            "runner_os": "ubuntu-26.04", "test_os": "ubuntu-26.04-arm", "target_cpu": "arm64"},
        "manylinux_aarch64:native": {
            "runner_os": "ubuntu-26.04-arm", "custom_clang": true, "build_params": "--use-sysroot --clang-path /opt/clang"},
        "manylinux_armv7l": {
            "runner_os": "ubuntu-26.04", "test_os": "ubuntu-26.04-arm", "target_cpu": "arm"},
        "manylinux_ppc64le": {
            "runner_os": "ubuntu-26.04", "target_cpu": "ppc64"},
        "manylinux_mips64le": {
            "runner_os": "ubuntu-24.04", "target_cpu": "mips64el"},
        "manylinux_mipsle": {
            "runner_os": "ubuntu-24.04", "target_cpu": "mipsel", "docker_test": false},
        "android_arm64_v8a": {
            "runner_os": "ubuntu-26.04", "target_os": "android", "target_cpu": "arm64"},
        "android_armeabi_v7a": {
            "runner_os": "ubuntu-26.04", "target_os": "android", "target_cpu": "arm"}
    }
}
