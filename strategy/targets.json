    "sbuild": {
        "macosx_arm64": {"runner_os": "macos-latest"},
        "macosx_x86_64": {
            "runner_os": "macos-latest", "target_cpu": "x64",
            "test_os": "macos-15-intel"
        },
        "macosx_x86_64:native": {"runner_os": "macos-15-intel"},
        "win_amd64": {"runner_os": "windows-latest"},
        "win32": {"runner_os": "windows-latest"},
        "win_arm64": {
            "runner_os": "windows-latest", "target_cpu": "arm64",
            "test_os": "windows-11-vs2026-arm"
        },
        "win_arm64:native": {"runner_os": "windows-11-vs2026-arm"},
        "linux_x86_64": {"runner_os": "ubuntu-26.04"},
        "linux_i686": {"runner_os": "ubuntu-26.04", "target_cpu": "x86"},
        "linux_aarch64": {
            "runner_os": "ubuntu-26.04", "target_cpu": "arm64",
            "test_os": "ubuntu-26.04-arm"
        },
        "linux_aarch64:native": {
            "runner_os": "ubuntu-26.04-arm", "custom_clang": true,
            "build_params": "--use-sysroot --clang-path /opt/clang"
