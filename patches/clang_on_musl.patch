diff --git a/config/compiler/BUILD.gn b/config/compiler/BUILD.gn
index e755e86..4c6bf18 100644
--- a/config/compiler/BUILD.gn
+++ b/config/compiler/BUILD.gn
@@ -1338,8 +1338,11 @@ config("compiler_cpu_abi") {
   if ((is_posix && !is_apple) || is_fuchsia) {
     # CPU architecture. We may or may not be doing a cross compile now, so for
     # simplicity we always explicitly set the architecture.
+    # XXX(pypdfium2): Nope, don't do this for the native build, at least not on musl, as the targets here appear to assume glibc.
+    # PyPA static clang is pre-configured with the correct target triple via its clang.cfg file.
+    # For some reason, just the pdfium builds seem to work, but it causes issues when we want to run pdfium_unittest.
     if (current_cpu == "x64") {
-      if (is_clang && !is_android && !is_fuchsia && !is_chromeos_device) {
+      if (is_clang && false &&  !is_android && !is_fuchsia && !is_chromeos_device) {
         cflags += [ "--target=x86_64-unknown-linux-gnu" ]
         ldflags += [ "--target=x86_64-unknown-linux-gnu" ]
       } else {
@@ -1353,7 +1356,7 @@ config("compiler_cpu_abi") {
         ldflags += [ "-march=$cros_target_cpu_arch" ]
       }
     } else if (current_cpu == "x86") {
-      if (is_clang && !is_android && !is_chromeos_device) {
+      if (is_clang && false && !is_android && !is_chromeos_device) {
         cflags += [ "--target=i386-unknown-linux-gnu" ]
         ldflags += [ "--target=i386-unknown-linux-gnu" ]
       } else {
@@ -1365,7 +1368,7 @@ config("compiler_cpu_abi") {
         "-msse3",
       ]
     } else if (current_cpu == "arm") {
-      if (is_clang && !is_android && !is_chromeos_device) {
+      if (is_clang && false && !is_android && !is_chromeos_device) {
         cflags += [ "--target=arm-linux-gnueabihf" ]
         ldflags += [ "--target=arm-linux-gnueabihf" ]
       }
@@ -1374,7 +1377,7 @@ config("compiler_cpu_abi") {
         "-mfloat-abi=$arm_float_abi",
       ]
     } else if (current_cpu == "arm64") {
-      if (is_clang && !is_android && !is_fuchsia && !is_chromeos_device) {
+      if (is_clang && false && !is_android && !is_fuchsia && !is_chromeos_device) {
         cflags += [ "--target=aarch64-linux-gnu" ]
         ldflags += [ "--target=aarch64-linux-gnu" ]
       }
@@ -1386,7 +1389,7 @@ config("compiler_cpu_abi") {
     } else if (current_cpu == "mipsel") {
       ldflags += [ "-Wl,--hash-style=sysv" ]
       if (custom_toolchain == "") {
-        if (is_clang) {
+        if (is_clang && false) {
           if (is_android) {
             cflags += [ "--target=mipsel-linux-android" ]
             ldflags += [ "--target=mipsel-linux-android" ]
@@ -1471,7 +1474,7 @@ config("compiler_cpu_abi") {
     } else if (current_cpu == "mips") {
       ldflags += [ "-Wl,--hash-style=sysv" ]
       if (custom_toolchain == "") {
-        if (is_clang) {
+        if (is_clang && false) {
           cflags += [ "--target=mips-linux-gnu" ]
           ldflags += [ "--target=mips-linux-gnu" ]
         } else {
@@ -1517,7 +1520,7 @@ config("compiler_cpu_abi") {
       cflags += [ "-D__SANE_USERSPACE_TYPES__" ]
       ldflags += [ "-Wl,--hash-style=sysv" ]
       if (custom_toolchain == "") {
-        if (is_clang) {
+        if (is_clang && false) {
           if (is_android) {
             cflags += [ "--target=mips64el-linux-android" ]
             ldflags += [ "--target=mips64el-linux-android" ]
@@ -1580,7 +1583,7 @@ config("compiler_cpu_abi") {
     } else if (current_cpu == "mips64") {
       ldflags += [ "-Wl,--hash-style=sysv" ]
       if (custom_toolchain == "") {
-        if (is_clang) {
+        if (is_clang && false) {
           cflags += [ "--target=mips64-linux-gnuabi64" ]
           ldflags += [ "--target=mips64-linux-gnuabi64" ]
         } else {
@@ -1624,7 +1627,7 @@ config("compiler_cpu_abi") {
           cflags += [ "-maix64" ]
           ldflags += [ "-maix64" ]
         }
-      } else if (is_clang) {
+      } else if (is_clang && false) {
         cflags += [ "--target=powerpc64le-unknown-linux-gnu" ]
         ldflags += [ "--target=powerpc64le-unknown-linux-gnu" ]
       } else {
@@ -1632,22 +1635,22 @@ config("compiler_cpu_abi") {
         ldflags += [ "-m64" ]
       }
     } else if (current_cpu == "riscv64") {
-      if (is_clang && !is_android) {
+      if (is_clang && false && !is_android) {
         cflags += [ "--target=riscv64-linux-gnu" ]
         ldflags += [ "--target=riscv64-linux-gnu" ]
       }
-      cflags += [ "-mabi=lp64d" ]
+      # cflags += [ "-mabi=lp64d" ]
     } else if (current_cpu == "loong64") {
-      if (is_clang) {
+      if (is_clang && false) {
         cflags += [ "--target=loongarch64-linux-gnu" ]
         ldflags += [ "--target=loongarch64-linux-gnu" ]
       }
       cflags += [
-        "-mabi=lp64d",
+        # "-mabi=lp64d",
         "-mcmodel=medium",
       ]
     } else if (current_cpu == "s390x") {
-      if (is_clang) {
+      if (is_clang && false) {
         cflags += [ "--target=s390x-unknown-linux-gnu" ]
         ldflags += [ "--target=s390x-unknown-linux-gnu" ]
       }
